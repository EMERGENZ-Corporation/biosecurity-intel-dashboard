MAX_DATA_AGE_HOURS=48
MAX_OFFICIAL_CHECK_AGE_HOURS=12
STATUS_URL=https://biosecurity-intel.emergenzsystems.org/status.json
MAX_STATUS_GENERATED_AGE_HOURS=8

# Optional server-side AI/news enrichment. Do not expose these with VITE_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_NEWS_ENRICHMENT=1
MAX_AI_NEWS_ITEMS=80
MAX_AI_PUBLIC_TAG_ADDS=80

# Optional Bright Data context fallback for low-risk news triage only.
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=biosecurity_web_unlocker
BRIGHT_DATA_NEWS_CONTEXT=1
MAX_BRIGHT_DATA_CONTEXT_ITEMS=5
