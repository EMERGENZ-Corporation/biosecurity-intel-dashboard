# Status freshness thresholds. Aligned with the actual human review cadence
# for structured signal data (CONTENT-STANDARDS §3.4 — `lastChecked` is a
# humans-only field). Tighter values produce false-alarm `degraded` status
# on every weekend; matching MAX_SIGNAL_STALE_HOURS=168 is the realistic floor.
MAX_DATA_AGE_HOURS=168
MAX_OFFICIAL_CHECK_AGE_HOURS=168
STATUS_URL=https://biosecurity-intel.emergenzsystems.org/status.json
# Production Status Monitor threshold — comfortably above the daily Status
# Refresh cadence so missed refresh/deploy cycles trip the alert without
# false-alarming on normal daily turnover.
MAX_STATUS_GENERATED_AGE_HOURS=30

# Optional server-side AI/news enrichment. Do not expose these with VITE_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_NEWS_ENRICHMENT=1
MAX_AI_NEWS_ITEMS=80
MAX_AI_PUBLIC_TAG_ADDS=80

# Optional Bright Data context fallback for low-risk news triage only.
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=biosecurity_web_unlocker
BRIGHT_DATA_NEWS_CONTEXT=1
MAX_BRIGHT_DATA_CONTEXT_ITEMS=5

# Weval evaluation pipeline. The OPENAI key is used ONLY by
# scripts/run-weval.mjs as the judge model for blueprint runs; never
# expose to update-news.yml or any other workflow. Production stays
# Gemini-only — the judge is deliberately a different vendor to avoid
# self-grading bias. See RUNBOOK §2.7.
OPENAI_API_KEY=
WEVAL_MODEL=google:gemini-2.5-flash
WEVAL_JUDGE_MODEL=openai:gpt-4o-mini
